rRMSE_mmse_comp_mean_without_covid
# M-SSA vs mean
rRMSE_mSSA_comp_mean_without_covid
# M-MSE vs M-SSA:
# - rRMSE < 1 -> M-MSE outperforms M-SSA
rRMSE_mmse_comp_mssa_without_covid
rRMSE_mmse_comp_mean_without_covid
round(rRMSE_mmse_comp_mean_without_covid,2)
